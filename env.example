RPC_URL_ETHEREUM=http://10.11.12.43:8545
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_URL_OPTIMISM=https://mainnet.optimism.io
RPC_URL_BASE=https://mainnet.base.org
ETHERSCAN_TOKEN=your_etherscan_api_key
VIRTUAL_HOST=localhost
# Frontend API base URL (leave empty to use relative URLs through Traefik)
VITE_API_BASE_URL=
# Sentry DSN for backend error tracking (leave empty to disable)
SENTRY_DSN=
# Sentry DSN for frontend error tracking (leave empty to disable)
VITE_SENTRY_DSN=
# ypricemagic in-memory cache size limits (number of entries)
YPRICEMAGIC_DEFAULT_CACHE_MAXSIZE=50000
YPRICEMAGIC_BLOCK_CACHE_MAXSIZE=500000
YPRICEMAGIC_CONTRACT_CACHE_MAXSIZE=50000
YPRICEMAGIC_PRICE_CACHE_MAXSIZE=100000
YPRICEMAGIC_CHECKSUM_CACHE_MAXSIZE=100000
# ypricemagic cache TTLs (seconds)
YPRICEMAGIC_CACHE_TTL=3600
YPRICEMAGIC_AMOUNT_CACHE_TTL=300
YPRICEMAGIC_CONTRACT_CACHE_TTL=3600
